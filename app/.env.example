# @required: true
# @type: url
# @pattern: ^https?://
VITE_API_ORIGIN=https://api.example.com

# @required: true for public live preview
# @type: url
# @pattern: ^https?://
VITE_AGENT_RUNTIME_BASE_URL=https://agent.example.com

# @required: true for GitHub Pages builds
# @type: enum
# @values: disabled,live
# @default: disabled
VITE_PUBLIC_RUNTIME_MODE=disabled

# @required: true for public builds
# @type: boolean
# @default: false
VITE_ALLOW_LOCAL_CREATOR_FALLBACK=false

# @required: true
# @type: ws_url
VITE_WS_URL=wss://api.example.com/ws

# @required: false
# @type: boolean
# @default: false
VITE_API_LOCAL=false

# Deprecated compatibility fallback
VITE_API_BASE_URL=/v1

# Supabase edge-only Data API client config.
# These browser-side keys are allowed to be public; RLS and grants are the
# security boundary. Never use secret/service_role keys in the frontend.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<browser-publishable-or-legacy-anon-key>
