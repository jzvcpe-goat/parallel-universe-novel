# P128 Operator Assignment Env Template
#
# Copy this file to:
# deploy/runtime-production/remote-assignment.env.local
#
# Fill only non-secret deployment evidence. Keep provider credentials, model
# keys, database connection strings, private keys and bridge tokens in the
# hosting provider secret store.
#
# Load locally before P117/P116:
# set -a
# . ./deploy/runtime-production/remote-assignment.env.local
# set +a

REMOTE_OPERATOR_OWNER=
REMOTE_OPERATOR_PROVIDER=
REMOTE_RUNTIME_ENVIRONMENT=production

REMOTE_API_SERVICE_ID=
REMOTE_AGENT_SERVICE_ID=

REMOTE_API_ORIGIN=
REMOTE_AGENT_ORIGIN=

REMOTE_API_SECRETS_CONFIGURED=false
REMOTE_AGENT_SECRETS_CONFIGURED=false
