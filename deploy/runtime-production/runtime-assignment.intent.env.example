# P146 Edge-Only Runtime Assignment Intent Env Template
#
# Copy this file to:
# deploy/runtime-production/runtime-assignment.intent.env.local
#
# Fill only non-secret deployment evidence. Do not put Supabase service-role
# keys, writer passwords, model provider keys, database URLs, bridge tokens, or
# private reference material in this file.
#
# Use locally:
# RUNTIME_ASSIGNMENT_INTENT_ENV_FILE=deploy/runtime-production/runtime-assignment.intent.env.local \
# RUNTIME_ASSIGNMENT_INTENT_FORCE=true \
# npm run prepare:runtime-assignment-intent
# npm run remote-assignment:prepare
# npm run remote-health:check
#
# Put the local-only publishable/anon key in .env.local or .env.local.sync, not
# in this intent file. P151 accepts VITE_SUPABASE_PUBLISHABLE_KEY,
# VITE_SUPABASE_ANON_KEY, SUPABASE_PUBLISHABLE_KEY or SUPABASE_ANON_KEY.

RUNTIME_ASSIGNMENT_ENVIRONMENT=production
RUNTIME_ASSIGNMENT_OPERATOR_OWNER=
RUNTIME_ASSIGNMENT_OPERATOR_PROVIDER=github-pages-supabase-managed

# Leave frontend fields blank unless the GitHub Pages repository changes.
RUNTIME_ASSIGNMENT_FRONTEND_PROVIDER=
RUNTIME_ASSIGNMENT_FRONTEND_SERVICE_ID=
RUNTIME_ASSIGNMENT_FRONTEND_ORIGIN=
RUNTIME_ASSIGNMENT_FRONTEND_URL=
RUNTIME_ASSIGNMENT_FRONTEND_CONFIGURED=true

# Managed data API evidence. Service-role keys and writer passwords stay out.
RUNTIME_ASSIGNMENT_DATA_API_PROVIDER=supabase
RUNTIME_ASSIGNMENT_DATA_API_SERVICE_ID=
SUPABASE_PROJECT_REF=
RUNTIME_ASSIGNMENT_DATA_API_ORIGIN=
SUPABASE_URL=
RUNTIME_ASSIGNMENT_DATA_API_CONFIGURED=false

RUNTIME_ASSIGNMENT_DATA_PROBE_TABLE=health_probe
RUNTIME_ASSIGNMENT_DATA_PROBE_ID=reader
