# P66 Remote Runtime Origin Provisioning Template
#
# This file is documentation for operators. Do not commit real secrets here.
# FastAPI and Agent Runtime must use the same Tool Bridge token value in the
# hosting provider secret store. GitHub Pages must only receive public VITE_*
# repository variables.

# FastAPI runtime
NARRATIVEOS_DEPLOY_ENV=production
DATABASE_URL=<production-or-preview-database-url>
NARRATIVEOS_ALLOWED_ORIGINS=https://jzvcpe-goat.github.io
NARRATIVEOS_TOOL_BRIDGE_TOKEN=<shared-tool-bridge-secret>
NARRATIVEOS_CREATOR_DIALOGUE_DIR=<persistent-creator-dialogue-dir>
NARRATIVEOS_CANON_LEDGER_DIR=<persistent-canon-ledger-dir>

# Agent Runtime
NODE_ENV=production
MASTRA_HOST=0.0.0.0
MASTRA_PORT=4111
MASTRA_TOOL_BRIDGE_BASE_URL=https://<api-host>
MASTRA_TOOL_BRIDGE_TOKEN=<shared-tool-bridge-secret>
MASTRA_ALLOWED_ORIGINS=https://jzvcpe-goat.github.io

# GitHub repository variables for Pages
VITE_PUBLIC_RUNTIME_MODE=live
VITE_API_ORIGIN=https://<api-host>
VITE_AGENT_RUNTIME_BASE_URL=https://<agent-host>
VITE_API_BASE_URL=https://<api-host>/v1
VITE_ALLOW_LOCAL_CREATOR_FALLBACK=false
