{
  "name": "@narrativeos/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mastra orchestration boundary for NarrativeOS creator workflows.",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "node --test \"dist/**/*.test.js\"",
    "pretest": "npm run build",
    "debug:pipeline": "tsx scripts/debug-pipeline.ts",
    "debug:constraints": "tsx scripts/debug-constraints.ts",
    "debug:quality": "tsx scripts/debug-quality.ts",
    "debug:cost": "tsx scripts/debug-cost.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.42.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  }
}
