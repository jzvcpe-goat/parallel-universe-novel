          "pressure": [
            "偏殿檐角的风卷下来，连铃索都只轻轻一晃，谁也不肯先退。"
          ],
          "pivot": [
            "他指节在剑柄上一松一紧，那点迟疑比任何一句话都更像裂口。"
          ],
          "aftermath": [
            "表面上无人失态，可散开时每个人周身的气机都比来时更沉。"
          ],
          "echo": [
            "等灯焰再跳一下时，那些没说尽的旧誓便像在骨血里缓缓回响。"
          ],
          "repeat": [
            "动作极轻，可谁都知道这层平静已经压不住真正的反噬。"
          ]
        },
        "temptation": {
          "entry": [
            "先动的不是人，而是照骨灯里那一点忽明忽暗的灵火。"
          ],
          "pressure": [
            "灯焰一偏，连影子都像替人把那点执念照得更清。"
          ],
          "pivot": [
            "两股气机在半空里轻轻一撞，谁都知道这回再退只会更痛。"
          ],
          "aftermath": [
            "风过石阶，余震未散，像旧誓还在等一个人先认输。"
          ],
          "echo": [
            "越到后面，越能听见那点心魔在沉默里一点点抬头。"
          ],
          "repeat": [
            "没人真出手，可那点诱惑已经顺着灵息渗进了骨头里。"
          ]
        },
        "mask_crack": {
          "entry": [
            "他嘴上仍压得平稳，袖中的真气却先露了一丝乱。"
          ],
          "pressure": [
            "她不再逼近，只把那一点看穿了的沉默稳稳放在两人之间。"
          ],
          "pivot": [
            "那层大道与私心的壳终于裂了一缝，谁都装不回去了。"
          ],
          "aftermath": [
            "场面没有炸开，真正的失守却已经在心里落了地。"
          ],
          "echo": [
            "等下一次再开口时，谁都回不到还能强讲大道的那一边。"
          ]
        },
        "confession_window": {
          "entry": [
            "偏殿忽然静极，连灯焰的轻响都像替这句真话腾出了位置。"
          ],
          "pressure": [
            "他把呼吸压到最稳，反而更显得那句想说的话早已顶到喉间。"
          ],
          "pivot": [
            "她没有替他收拾场面，只把那点空白留成了最逼人的台阶。"
          ],
          "aftermath": [
            "真话一落下来，连周围的灵息都像跟着轻了一瞬。"
          ],
          "echo": [
            "这一回先说到这里，可真正的取舍还要到下一次见面时才算数。"
          ]
        }
      }
    }
