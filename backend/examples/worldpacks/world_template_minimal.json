    "protagonist": {
      "profile_id": "lead",
      "cadence": "measured",
      "directness": 0.52,
      "bluntness": 0.48,
      "restraint": 0.58,
      "social_rank_awareness": 0.52,
      "hesitation_style": "把更难听的话先咽半口",
      "direct_address_style": "先看对方，再把话送出去",
      "opening_style": [
        "我知道这条路一旦走出去，就不会再只是我一个人的事。"
      ],
      "pressure_style": [
        "你若真要逼我承认，那我也不能再装作无事发生。"
      ],
      "pivot_style": [
        "真正难的不是看见真相，是看见以后还要不要继续往前走。"
      ],
      "aftermath_style": [
        "这句话落下去以后，后面的代价就已经跟上来了。"
      ],
      "echo_style": [
        "下一次开口时，谁都不可能还是刚才那个人。"
      ]
    }
  },
  "response_cadence_profiles": {
    "protagonist": {
      "cadence_id": "lead",
      "reaction_tempo": "measured",
      "reaction_lines": {
        "entry": [
          "他没有立刻接话，只让那句意思先在心里过了一遍。"
        ],
        "pressure": [
          "他手上的细小动作先停住了，像终于不打算再替谁留余地。"
        ],
        "pivot": [
          "他这才抬起眼来，语气仍不见急，可越平，越像逼人。"
        ],
        "aftermath": [
          "他临到收声时反而更轻了些，可那点轻偏偏更重。"
        ],
        "echo": [
          "他没有再追，可沉默已经替下一次相见留了一道裂口。"
        ]
      },
      "reply_lines": {
        "entry": [
          "这句话既然出口，就别再往回收。"
        ],
        "pressure": [
          "你总得先替自己承认一次。"
        ],
        "pivot": [
          "再退半步，也只是让伤口换个地方继续裂。"
        ],
        "aftermath": [
          "这事不会就这样过去。"
        ],
        "echo": [
          "等你再来，就别只带着半句真话。"
        ]
      }
    }
  },
  "pressure_response_styles": {
    "protagonist": {
      "style_id": "lead",
      "under_pressure": "嘴上更轻，动作更硬",
      "when_cornered": "先沉默，再把难听的话说实",
      "when_softening": "语气微松，但不立刻退让",
      "when_deflecting": "把真正的心事往旁处挪半寸"
    }
  },
  "emotion_action_policies": {
    "default": {
      "policy_id": "world_template_minimal_default_action",
      "action_map": {
        "false_peace": {
          "entry": [
            "桌上的器物轻轻一碰，谁都知道这一步已经走出去，很难再收回来。"
          ],
          "pressure": [
            "最细小的抬眼和换气都带上了掂量，像谁先多动一下，谁就会先露底。"
          ],
          "pivot": [
            "那一点极轻的停顿和改口，让场面从还能周旋，变成了不得不选边。"
          ],
          "aftermath": [
            "人散得不快，沉默却先压了下来。"
          ],
          "echo": [
            "越到后面，越能听见那些没说尽的话慢慢回身。"
          ],
          "repeat": [
            "动作并不大，可谁都知道事情已经换了味道。"
          ]
        },
        "truth_trial": {
          "entry": [
            "先动的不是声音，而是视线和手指那一点收紧。"
          ],
          "pressure": [
            "杯沿上那一点冷光轻轻一闪，连呼吸都像被逼慢了半拍。"
          ],
          "pivot": [
            "风从门缝里钻进来，把场里的沉默一下子吹偏了方向。"
          ],
          "aftermath": [
            "茶香已经淡了，场里的气却还迟迟不肯散开。"
          ],
          "echo": [
            "等人散尽以后，连空下来的位置都还像留着刚才那句重话。"
          ],
          "repeat": [
            "动作不大，可谁都知道这句真话已经绕不过去了。"
          ]
        }
      }
    }
