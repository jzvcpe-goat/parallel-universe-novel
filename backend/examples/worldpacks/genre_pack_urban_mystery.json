          "pressure": [
            "天桥下的风卷过来，吹得塑料棚布轻轻一响，把每个字都衬得更硬。"
          ],
          "pivot": [
            "他指尖一松，扣在掌心里的钥匙先撞出一声轻响。"
          ],
          "aftermath": [
            "一句话落下去以后，谁都没有立刻挪步，像还在等更难听的那半句。"
          ],
          "echo": [
            "路灯把影子拉得很长，倒像是把没说透的旧账一并拖了出来。"
          ],
          "repeat": [
            "谁先多看一眼，谁就像先把底牌从袖口里滑出来。"
          ]
        },
        "mask_crack": {
          "entry": [
            "他嘴上还撑着，指尖却先在打火机壳上停住了。"
          ],
          "pressure": [
            "她把目光收得极稳，像是在等那层嘴硬自己先裂。"
          ],
          "pivot": [
            "一句话没拐过去，连站姿都跟着露了怯。"
          ],
          "aftermath": [
            "场面表面还稳着，裂口却已经落到了每个人心里。"
          ],
          "echo": [
            "再往下走时，谁也回不到刚才那副没事人的样子。"
          ]
        },
        "confession_window": {
          "entry": [
            "旧巷忽然安静下来，连远处车声都像给这句真话让了道。"
          ],
          "pressure": [
            "他把那口气压了又压，最后还是没能把话咽回去。"
          ],
          "pivot": [
            "她没替他补台阶，只把那一瞬的沉默留成了逼人的空白。"
          ],
          "aftermath": [
            "真话一落地，连站在原地都比刚才更像一种选择。"
          ],
          "echo": [
            "哪怕这次先收住了，下一次见面时也不可能装作没发生。"
          ]
        }
