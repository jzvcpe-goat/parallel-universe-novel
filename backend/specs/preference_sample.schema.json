{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PreferenceSample",
  "type": "object",
  "required": [
    "preference_id",
    "world_id",
    "world_version_id",
    "reviewer_id",
    "left_revision_id",
    "right_revision_id",
    "preferred_revision_id",
    "freeform_notes",
    "preference_strength",
    "created_at",
    "source"
  ],
  "properties": {
    "preference_id": {"type": "string"},
    "world_id": {"type": "string"},
    "world_version_id": {"type": "string"},
    "chapter_id": {"type": ["string", "null"]},
    "session_id": {"type": ["string", "null"]},
    "reviewer_id": {"type": "string"},
    "left_revision_id": {"type": "string"},
    "right_revision_id": {"type": "string"},
    "preferred_revision_id": {"type": "string"},
    "freeform_notes": {"type": "string"},
    "linked_issue_codes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "preference_strength": {
      "type": "string",
      "enum": ["strong", "medium", "weak"]
    },
    "created_at": {"type": "string"},
    "source": {
      "type": "string",
      "enum": ["human_preference"]
    },
    "ingestion_meta": {
      "type": "object",
      "properties": {
        "ingestion_key": {"type": "string"},
        "reference_status": {"type": "string"},
        "ingested_at": {"type": "string"},
        "storage_mode": {"type": "string"},
        "ingestion_warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
