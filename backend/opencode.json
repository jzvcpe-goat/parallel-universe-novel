{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder:7b",
  "small_model": "ollama/qwen2.5-coder:7b",
  "default_agent": "build",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B"
        }
      }
    }
  },
  "enabled_providers": ["ollama"],
  "server": {
    "hostname": "127.0.0.1",
    "port": 4097
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "watcher": {
    "ignore": [
      ".venv/**",
      ".pytest_cache/**",
      "__pycache__/**",
      "*.db",
      "*.sqlite",
      "*.sqlite3"
    ]
  }
}
