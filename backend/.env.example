OPENAI_API_KEY=replace_me
NARRATIVEOS_DEFAULT_MODEL=gpt-5.3-codex
NARRATIVEOS_POLICY_FILE=configs/policy.example.yaml
NARRATIVEOS_SCORING_FILE=configs/scoring_weights.yaml

# Model-agnostic creator dialogue runtime
# Without a creator provider, /v1/creator/dialogue/* stays usable through the local cowriter fallback.
# OpenAI-compatible providers include DeepSeek, Moonshot, Qwen, Zhipu, OpenRouter, and many local gateways.
# NARRATIVEOS_CREATOR_PROVIDER=openai_compatible
# NARRATIVEOS_CREATOR_PROVIDER_ORDER=openai_compatible,openai,anthropic,gemini,local
# NARRATIVEOS_CREATOR_API_KEY=replace_me
# NARRATIVEOS_CREATOR_BASE_URL=https://api.deepseek.com/v1
# NARRATIVEOS_CREATOR_MODEL=deepseek-chat
# NARRATIVEOS_CREATOR_DIALOGUE_DIR=artifacts/creator_dialogue_sessions

NARRATIVEOS_BILLING_PROVIDER=web_stub
NARRATIVEOS_CHECKOUT_SESSION_TTL_MINUTES=60
NARRATIVEOS_BILLING_RETRY_MAX_ATTEMPTS=3
NARRATIVEOS_BILLING_RETRY_BACKOFF_MINUTES=30
NARRATIVEOS_APP_BASE_URL=http://127.0.0.1:8000/app
NARRATIVEOS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://jzvcpe-goat.github.io
NARRATIVEOS_OPS_ALERT_PAYMENT_REQUIRED_THRESHOLD=2
NARRATIVEOS_OPS_ALERT_RUNTIME_FALLBACK_THRESHOLD=2
NARRATIVEOS_OPS_ALERT_FAILED_JOB_THRESHOLD=1

# Stripe sandbox / test mode wiring
# Switch provider from web_stub to stripe when you have valid Stripe test keys and prices.
# NARRATIVEOS_BILLING_PROVIDER=stripe
# NARRATIVEOS_STRIPE_SECRET_KEY=sk_test_replace_me
# NARRATIVEOS_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# NARRATIVEOS_STRIPE_WEBHOOK_SECRET=whsec_replace_me
# NARRATIVEOS_STRIPE_PRICE_MAP_JSON='{"play_pass":"price_replace_play","creator_pass":"price_replace_creator","studio_pass":"price_replace_studio"}'
# NARRATIVEOS_API_BASE_URL=http://127.0.0.1:8000
# NARRATIVEOS_STRIPE_VERIFY_ACCOUNT_ID=reader_sandbox@example.com
# NARRATIVEOS_STRIPE_VERIFY_PASSWORD=secret123
# NARRATIVEOS_STRIPE_VERIFY_TIER=play_pass

# Transactional email / account recovery
# EMAIL_MODE=test
# EMAIL_PROVIDER=stub
# APP_BASE_URL=http://127.0.0.1:8000/app
# EMAIL_VERIFICATION_TOKEN_TTL=172800
# PASSWORD_RESET_TOKEN_TTL=7200
# EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# EMAIL_SEND_ALLOWLIST=delivered@resend.dev,@resend.dev
# AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_NAME=narrativeos_auth
# AUTH_COOKIE_SAMESITE=lax

# Resend sender configuration
# Switch EMAIL_PROVIDER=resend only after RESEND_API_KEY is present.
# In test mode, only Resend test inboxes and EMAIL_SEND_ALLOWLIST recipients are allowed.
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_replace_me
# RESEND_FROM_EMAIL=onboarding@mail.lixidol.com
# RESEND_FROM_NAME=NarrativeOS
# RESEND_REPLY_TO=support@lixidol.com
# RESEND_VERIFIED_DOMAIN_STATUS=unverified

# Legacy email aliases kept for compatibility with older local setups
# NARRATIVEOS_EMAIL_PROVIDER=resend
# NARRATIVEOS_EMAIL_FROM=NarrativeOS <onboarding@resend.dev>
# NARRATIVEOS_EMAIL_REPLY_TO=support@example.com

# App Store billing
# NARRATIVEOS_APPLE_BILLING_BEARER_TOKEN=replace_me
# NARRATIVEOS_APPLE_BILLING_ENV=sandbox
# NARRATIVEOS_APPLE_TIER_MAP_JSON='{"com.narrativeos.play_pass":"play_pass","com.narrativeos.creator_pass":"creator_pass","com.narrativeos.studio_pass":"studio_pass"}'

# Google Play billing
# NARRATIVEOS_GOOGLE_PLAY_ACCESS_TOKEN=replace_me
# NARRATIVEOS_GOOGLE_PLAY_PACKAGE_NAME=com.narrativeos.app
# NARRATIVEOS_GOOGLE_PLAY_ENV=production
# NARRATIVEOS_GOOGLE_PLAY_TIER_MAP_JSON='{"play_pass":"play_pass","creator_pass":"creator_pass","studio_pass":"studio_pass"}'
