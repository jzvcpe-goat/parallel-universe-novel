{
  "name": "parallel-universe-novel",
  "version": "1.0.0",
  "private": true,
  "description": "平行宇宙小说 Creator Studio, FastAPI runtime, and Mastra agent orchestration.",
  "main": "index.js",
  "workspaces": [
    "app",
    "packages/agent-runtime"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev:infra": "node scripts/dev-infra-placeholder.mjs",
    "dev:api": "node scripts/run-backend-python.mjs -m uvicorn narrativeos.api.app_factory:create_app --factory --app-dir backend/src --host 127.0.0.1 --port 8787 --reload",
    "dev:agents": "npm --workspace @narrativeos/agent-runtime run dev",
    "dev:creator": "npm --prefix app run dev -- --host 127.0.0.1 --port 5173",
    "dev": "node scripts/dev-all.mjs",
    "setup:api": "node scripts/setup-backend-venv.mjs",
    "test": "npm --workspace @narrativeos/agent-runtime test && npm --prefix app run lint && node scripts/run-backend-python.mjs -m pytest backend/tests/test_creator_dialogue_api.py backend/tests/test_tool_bridge_api.py backend/tests/test_market_trends_api.py && npm run scan:internal-terms && npm run scan:p4-rule-source && npm run scan:reference-privacy",
    "test:agents": "npm --workspace @narrativeos/agent-runtime test",
    "test:api": "node scripts/run-backend-python.mjs -m pytest backend/tests/test_creator_dialogue_api.py backend/tests/test_tool_bridge_api.py",
    "test:creator": "npm --prefix app run lint",
    "debug:pipeline": "npm --workspace @narrativeos/agent-runtime run debug:pipeline --",
    "debug:constraints": "npm --workspace @narrativeos/agent-runtime run debug:constraints --",
    "debug:quality": "npm --workspace @narrativeos/agent-runtime run debug:quality --",
    "debug:cost": "npm --workspace @narrativeos/agent-runtime run debug:cost --",
    "scan:internal-terms": "node scripts/scan-internal-terms.mjs",
    "scan:p4-rule-source": "node scripts/scan-p4-rule-source.mjs",
    "scan:reference-privacy": "node scripts/scan-reference-privacy.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
