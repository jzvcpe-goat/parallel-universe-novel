{
  "name": "parallel-universe-novel",
  "version": "1.0.0",
  "private": true,
  "description": "平行宇宙小说 Creator Studio, FastAPI runtime, and Mastra agent orchestration.",
  "main": "index.js",
  "workspaces": [
    "app",
    "packages/agent-runtime"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev:infra": "node scripts/dev-infra-placeholder.mjs",
    "dev:api": "node scripts/run-backend-python.mjs -m uvicorn narrativeos.api.app_factory:create_app --factory --app-dir backend/src --host 127.0.0.1 --port 8787 --reload",
    "dev:agents": "npm --workspace @narrativeos/agent-runtime run dev",
    "dev:creator": "npm --prefix app run dev -- --host 127.0.0.1 --port 5173",
    "dev": "node scripts/dev-all.mjs",
    "setup:api": "node scripts/setup-backend-venv.mjs",
    "test": "npm --workspace @narrativeos/agent-runtime test && npm --prefix app run lint && node scripts/run-backend-python.mjs -m pytest backend/tests/test_creator_dialogue_api.py backend/tests/test_tool_bridge_api.py backend/tests/test_market_trends_api.py && npm run check:package-identity && npm run check:release-sync-manifest && npm run check:template-intent && npm run check:runtime-rule-handshake && npm run check:public-runtime-boundary && npm run check:github-pages-spa-fallback && npm run scan:internal-terms && npm run scan:public-ui-boundary && npm run scan:p4-rule-source && npm run scan:reference-privacy",
    "test:agents": "npm --workspace @narrativeos/agent-runtime test",
    "test:api": "node scripts/run-backend-python.mjs -m pytest backend/tests/test_creator_dialogue_api.py backend/tests/test_tool_bridge_api.py",
    "test:creator": "npm --prefix app run lint",
    "smoke:creator-chain": "node scripts/smoke-creator-chain.mjs",
    "qa:creator-browser": "node scripts/browser-creator-e2e.mjs",
    "check:package-identity": "node scripts/check-package-identity.mjs",
    "check:release-sync-manifest": "node scripts/check-release-sync-manifest.mjs",
    "check:public-runtime-boundary": "node scripts/check-public-runtime-boundary.mjs",
    "check:github-pages-spa-fallback": "node scripts/check-github-pages-spa-fallback.mjs",
    "check:template-intent": "node scripts/check-template-intent-routing.mjs",
    "check:runtime-rule-handshake": "node scripts/check-runtime-rule-handshake.mjs",
    "debug:pipeline": "npm --workspace @narrativeos/agent-runtime run debug:pipeline --",
    "debug:constraints": "npm --workspace @narrativeos/agent-runtime run debug:constraints --",
    "debug:quality": "npm --workspace @narrativeos/agent-runtime run debug:quality --",
    "debug:cost": "npm --workspace @narrativeos/agent-runtime run debug:cost --",
    "scan:internal-terms": "node scripts/scan-internal-terms.mjs",
    "scan:public-ui-boundary": "node scripts/scan-public-ui-boundary.mjs",
    "scan:p4-rule-source": "node scripts/scan-p4-rule-source.mjs",
    "scan:reference-privacy": "node scripts/scan-reference-privacy.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
